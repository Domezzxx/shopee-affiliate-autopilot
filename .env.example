# ============================================================
#  Affiliate Autopilot — คัดลอกไฟล์นี้เป็น  .env  แล้วเติมค่า
#  คำสั่ง (PowerShell):  Copy-Item .env.example .env
# ============================================================

# ---------- AI สมอง: ใครเขียนคอนเทนต์ ----------
# CONTENT_PROVIDER=gemini  → ใช้ Gemini เขียน (ฟรี! แนะนำช่วงทดสอบ ไม่ต้องใช้ Claude)
# CONTENT_PROVIDER=claude  → ใช้ Claude เขียน (จ่ายเงิน คุณภาพไทยสูงสุด ตอนใช้จริง)
CONTENT_PROVIDER=gemini

# Claude (ทางเลือก — จ่ายเงิน): https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
CONTENT_MODEL=claude-sonnet-4-6          # อยากเทพสุดเปลี่ยนเป็น claude-opus-4-8

# ---------- Gemini (ฟรี — เขียนข้อความ + ทำภาพ Nano Banana) ----------
# สมัครฟรีที่ https://aistudio.google.com/apikey  (ไม่ต้องผูกบัตร)
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash       # เขียนข้อความ (ฟรี)
IMAGE_MODEL=gemini-2.5-flash-image       # "Nano Banana" ทำภาพ
VIDEO_MODEL=veo-3.0-generate-001         # Google Veo (วีดีโอ — มักต้องจ่าย/มีลิมิต)
ENABLE_VIDEO=false                       # true = วีดีโอจริง (แพง) / false = ภาพ 9:16 อย่างเดียว (แนะนำตอนทดสอบ)

# ---------- Facebook + Instagram (Meta Graph API) ----------
# ต้องมี Facebook Page + IG Business + Long-lived Page Access Token + ผ่าน App Review
# permission: pages_manage_posts, pages_read_engagement, instagram_content_publish
META_PAGE_ID=
META_IG_USER_ID=
META_ACCESS_TOKEN=
# IG รับเฉพาะ public URL ของสื่อ → ต้องโฮสต์ /media ให้ public
# วิธีฟรี: รัน  ./scripts/start_tunnel.ps1  (cloudflared quick tunnel — เขียนค่านี้ให้อัตโนมัติ)
# เช่น https://xxxx.trycloudflare.com  (FB อัปไฟล์ตรงได้ ไม่ต้องใช้)
PUBLIC_BASE_URL=
ENABLE_POST_DELAY=false           # true = สุ่มหน่วง 15-45 นาทีระหว่างโพสต์ (โปรดักชัน กัน spam)

# ---------- YouTube (Data API v3 / OAuth refresh token) ----------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ---------- Phone Farm (6 เครื่อง — โพสต์สำรองเมื่อ API ไม่ครอบ) ----------
# เปิด ADB over TCP ที่เครื่องมือถือ แล้วใส่ IP:PORT คั่นด้วยจุลภาค
# เว้นว่าง = ปิด phone farm (ใช้แค่ API)
PHONE_FARM_DEVICES=               # เช่น 192.168.1.51:5555,192.168.1.52:5555
HOST_ADB=host.docker.internal:5037

# ---------- ดึงร้าน Shopee Food (Shopee กัน bot — direct โดนบล็อก 403) ----------
# SCRAPER_MODE=direct      → ยิงตรง (ฟรี แต่มักโดนบล็อก ใช้ทดสอบ/มี proxy เท่านั้น)
# SCRAPER_MODE=scraperapi  → ผ่าน ScraperAPI (ฟรี 1,000 ครั้ง/เดือน) สมัคร scraperapi.com
# SCRAPER_MODE=scrapingbee → ผ่าน ScrapingBee (ฟรี ~1,000 credits) สมัคร scrapingbee.com
# SCRAPER_MODE=apify       → รัน Apify actor (ฟรี $5 credit/เดือน) สมัคร apify.com
SCRAPER_MODE=scraperapi
SCRAPER_API_KEY=                  # key ของ ScraperAPI หรือ ScrapingBee
SCRAPER_PROXY=                    # http://user:pass@host:port (เฉพาะโหมด direct ถ้ามี proxy เอง)
APIFY_TOKEN=                      # ถ้าใช้ apify
APIFY_ACTOR=                      # เช่น youruser/shopee-food-scraper
SHOPEE_KEYWORDS=ร้านอาหารอร่อย อุดรธานี   # คำค้น (คั่นหลายคำด้วย ; / คำสุดท้าย = ย่าน)
SCRAPER_LIMIT=50

# ---------- การตั้งค่าระบบ ----------
POSTING_MODE=hybrid               # hybrid | api | phone
SHOPEE_MIN_RATING=4.5             # กรองร้าน: rating ขั้นต่ำ
SHOPEE_MIN_REVIEWS=20             # กรองร้าน: รีวิวขั้นต่ำ
ABTEST_MIN_IMPRESSIONS=500        # เก็บ impression ครบเท่านี้ค่อยตัดสิน A/B
ABTEST_PAUSE_CTR=0.005            # ร้าน CTR ต่ำกว่านี้ 3 วันติด → หยุดโพสต์ (ประหยัด cost)
POST_DELAY_MIN=15                 # สุ่ม delay ระหว่างโพสต์ (นาที) กัน spam detection
POST_DELAY_MAX=45
AUTO_OPTIMIZE_INTERVAL_MIN=360    # รอบ auto-optimize (นาที) = 6 ชม.
